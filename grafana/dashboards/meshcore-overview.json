          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', m.time) AS time,\n  COALESCE(r.label, m.repeater_id) AS metric,\n  GREATEST(MAX(m.total_air_time_secs) - MIN(m.total_air_time_secs), 0) / 3600.0 * 100 AS value\nFROM metrics m\nLEFT JOIN repeaters r ON r.repeater_id = m.repeater_id\nWHERE $__timeFilter(m.time) AND m.total_air_time_secs IS NOT NULL\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Airtime (% of hour) by repeater",
      "type": "timeseries"
    },
