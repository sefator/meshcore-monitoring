        {
          "datasource": {
            "type": "postgres",
            "uid": "meshcore-timescaledb"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(n.time, $__interval),\n  COALESCE(r.label, n.repeater_id) AS metric,\n  COUNT(*) AS value\nFROM neighbors n\nLEFT JOIN repeaters r ON r.repeater_id = n.repeater_id\nWHERE $__timeFilter(n.time)\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Neighbor sightings by repeater",
      "type": "timeseries"
    },
    {
