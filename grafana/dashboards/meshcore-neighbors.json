      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "meshcore-timescaledb"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(n.time, $__interval),\n  COALESCE(r.label, n.repeater_id) AS metric,\n  AVG(n.snr) AS value\nFROM neighbors n\nLEFT JOIN repeaters r ON r.repeater_id = n.repeater_id\nWHERE $__timeFilter(n.time) AND n.snr IS NOT NULL\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Average neighbor SNR by repeater",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "meshcore-timescaledb"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "meshcore-timescaledb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(r.label, n.repeater_id) AS repeater,\n  n.neighbor_id,\n  COUNT(*) AS sightings,\n  ROUND(AVG(n.snr)::numeric, 2) AS avg_snr,\n  MAX(n.time) AS last_seen\nFROM neighbors n\nLEFT JOIN repeaters r ON r.repeater_id = n.repeater_id\nWHERE $__timeFilter(n.time)\nGROUP BY 1, 2\nORDER BY sightings DESC, last_seen DESC\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Top observed neighbors",
      "type": "table"
    }
  ],
