          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(m.time, $__interval),\n  COALESCE(r.label, m.repeater_id) AS metric,\n  MAX(COALESCE(m.n_direct_dups, 0) + COALESCE(m.n_flood_dups, 0)) AS value\nFROM metrics m\nLEFT JOIN repeaters r ON r.repeater_id = m.repeater_id\nWHERE $__timeFilter(m.time) AND (m.n_direct_dups IS NOT NULL OR m.n_flood_dups IS NOT NULL)\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
