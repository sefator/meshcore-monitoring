# Device identity and auth signing come from the Meshcore device/companion at runtime.
# No DEVICE_ID / PUBLIC_KEY_HEX / PRIVATE_KEY_HEX env overrides are used by edge.
LOCATION_ID=demo-location
WINDOW_HOURS=8
INGEST_URL=http://localhost:8080/ingest
POLL_CONCURRENCY=1
REPEATERS_CONFIG_PATH=config/repeaters.json
COMPANION_CONNECTION=tcp
COMPANION_TCP_HOST=127.0.0.1
COMPANION_TCP_PORT=5000
COMPANION_SERIAL_PATH=/dev/ttyACM0
COMPANION_TELEMETRY_TIMEOUT_MS=15000
COMPANION_STATUS_TIMEOUT_MS=30000
AUTH_TOKEN_TTL_SECONDS=86400
