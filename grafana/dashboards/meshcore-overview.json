          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(r.label, latest.repeater_id) AS repeater,\n  latest.time AS last_sample,\n  latest.rssi,\n  latest.snr,\n  latest.battery,\n  latest.link_quality,\n  latest.neighbors_count,\n  latest.queue_len\nFROM (\n  SELECT DISTINCT ON (repeater_id)\n    repeater_id,\n    time,\n    rssi,\n    snr,\n    battery,\n    link_quality,\n    neighbors_count,\n    queue_len\n  FROM metrics\n  WHERE $__timeFilter(time)\n  ORDER BY repeater_id, time DESC\n) latest\nLEFT JOIN repeaters r ON r.repeater_id = latest.repeater_id\nORDER BY repeater;",
          "refId": "A"
        }
      ],
      "title": "Latest repeater samples",
      "type": "table"
