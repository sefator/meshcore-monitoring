          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', m.time) AS time,\n  COALESCE(r.label, m.repeater_id) AS metric,\n  GREATEST(MAX(COALESCE(m.n_direct_dups, 0) + COALESCE(m.n_flood_dups, 0)) - MIN(COALESCE(m.n_direct_dups, 0) + COALESCE(m.n_flood_dups, 0)), 0) AS value\nFROM metrics m\nLEFT JOIN repeaters r ON r.repeater_id = m.repeater_id\nWHERE $__timeFilter(m.time) AND (m.n_direct_dups IS NOT NULL OR m.n_flood_dups IS NOT NULL)\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
